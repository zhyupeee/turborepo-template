# ===========================================
# Turing Lab Platform 前端环境变量配置示例
# ===========================================
# 复制此文件为 .env.development、.env.test 或 .env.production
# 根据你的环境修改相应的值

# API 基础 URL
# 开发环境: http://localhost:3001/api
# 生产环境: /api (使用相对路径，由 nginx 代理)
VITE_API_BASE_URL=http://localhost:3001/api

# 应用环境标识
VITE_APP_ENV=development
