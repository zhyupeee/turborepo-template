{
  "name": "@repo/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rimraf dist .tsbuildinfo",
    "prebuild": "pnpm run clean",
    "build": "ts-patch install -s && tsc -p tsconfig.json",
    "start": "node -r tsconfig-paths/register dist/apps/backend/src/main.js",
    "start:prod": "node -r tsconfig-paths/register dist/apps/backend/src/main.js",
    "predev": "pnpm run build",
    "dev": "concurrently -n \"TSC,NODE\" -c \"cyan,magenta\" \"tsc -p tsconfig.json --watch\" \"node -r tsconfig-paths/register dist/apps/backend/src/main.js\"",
    "start:dev": "pnpm run dev",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm run typeorm -- migration:generate -d src/config/database.config.ts",
    "migration:run": "pnpm run typeorm -- migration:run -d src/config/database.config.ts",
    "migration:revert": "pnpm run typeorm -- migration:revert -d src/config/database.config.ts",
    "nestia": "node node_modules/nestia/bin/index.js swagger && node node_modules/nestia/bin/index.js sdk"
  },
  "dependencies": {
    "@nestia/core": "4.5.0",
    "@nestia/fetcher": "4.5.0",
    "@nestia/sdk": "4.5.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@samchon/openapi": "^4.5.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "mysql2": "^3.11.0",
    "nestia": "4.5.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20",
    "typia": "7.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@repo/typescript-config": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.15.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.20",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "ts-patch": "^3.3.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "ttypescript": "^1.5.15",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
