# ===========================================
# Turing Lab Platform 环境变量配置示例
# ===========================================
# 复制此文件为 .env.development、.env.test 或 .env.production
# 根据你的环境修改相应的值

# ===========================================
# 应用配置
# ===========================================

# 运行环境: development | test | production
NODE_ENV=development

# 服务端口
PORT=3001

# 日志级别: error | warn | log | debug | verbose
LOG_LEVEL=debug

# ===========================================
# 数据库配置
# ===========================================

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here

# 数据库名称 (建议不同环境使用不同数据库)
# 开发环境: turing_lab_dev
# 测试环境: turing_lab_test
# 生产环境: turing_lab
DB_DATABASE=turing_lab_dev

# ===========================================
# CORS 配置
# ===========================================

# 允许的跨域来源，多个用逗号分隔
# 开发环境示例: http://localhost:5173,http://localhost:3000
# 生产环境示例: https://your-domain.com
CORS_ORIGIN=http://localhost:5173
